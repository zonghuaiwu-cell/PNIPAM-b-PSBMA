#!/usr/bin/python
import sys
sys.path.append('/opt/galamost3/lib') # the path where the GALAMOST program is installed
import molgen
#import math


#er=13.87
#kBT=298.0*8.314/1000.0
#r=0.646
#gama=138.935
#dpdcharge=math.sqrt(gama/(er*kBT*r))



mol1=molgen.Molecule("model.xml",174960)#particle number

mol1.setMass(1.0)#mass




gen=molgen.Generators(36,36,45)
gen.addMolecule(mol1,1)#molecule, the number of molecules




gen.outPutXml("s1") #file name
gen.outPutMol2 ("s1")